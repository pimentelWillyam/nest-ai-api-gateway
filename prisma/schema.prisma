generator client {
  provider = "prisma-client"
  output   = "./generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  login     String   @unique
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userAiPermissions UserAiPermission[]

   @@map("users")

}

model AiService {
  id        String   @id @default(uuid())
  model      String
  slug      String   @unique
  url       String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userAiPermissions UserAiPermission[]

   @@map("ai_services")
}

model UserAiPermission {
  userId     String
  serviceId  String
  enabled    Boolean @default(true)

  user       User      @relation(fields: [userId], references: [id])
  service    AiService @relation(fields: [serviceId], references: [id])

  @@id([userId, serviceId])

   @@map("user_ai_permissions")

}